# Fiber MerchantOps Core — environment configuration
# Copy the values you need into apps/api-server/.env (the API server and Prisma read it from there).

# API server
PORT=8080
DATABASE_URL=file:./dev.db

# Fiber adapter: "simulated" (deterministic demo, enables /v1/demo endpoints) or "real" (Fiber node JSON-RPC)
FIBER_ADAPTER_MODE=simulated
FIBER_RPC_URL=http://127.0.0.1:8227
FIBER_RPC_TOKEN=

# Demo merchant seeded at API boot
DEFAULT_MERCHANT_ID=m_123
DEFAULT_WEBHOOK_SECRET=whsec_demo_secret
MERCHANT_DEMO_WEBHOOK_URL=http://localhost:9090/webhooks/fiber

# Companion processes
ADMIN_UI_PORT=5173
MERCHANT_DEMO_PORT=9090

# Webhook delivery worker
WEBHOOK_WORKER_INTERVAL_MS=1000
WEBHOOK_TIMEOUT_MS=5000

# Optional background payment-status poller (manual refresh is always available)
STATUS_POLL_ENABLED=false
STATUS_POLL_INTERVAL_MS=5000
